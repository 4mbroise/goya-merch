FROM node:20-alpine AS builder
WORKDIR /app

# Copy only storefront package files
COPY apps/storefront/package*.json ./

# Install storefront dependencies only (no workspace overhead)
RUN npm install

# Copy source
COPY apps/storefront .

# Build Next.js
RUN npm run build

# Production image
FROM node:20-alpine
WORKDIR /app

# Copy built app + node_modules
COPY --from=builder /app ./

ENV NODE_ENV=production
EXPOSE 9001
CMD ["npm", "run", "start"]
